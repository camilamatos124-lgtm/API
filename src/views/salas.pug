doctype html
html(lang="pt-BR")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Painel de Salas - Rave Party
    style.
      body {
        background-color: #0d0e15;
        color: #fff;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 40px;
        margin: 0;
      }
      .header {
        text-align: center;
        margin-bottom: 50px;
      }
      h1 {
        color: #00f3ff;
        text-shadow: 0 0 15px #00f3ff;
        font-size: 2.5rem;
        text-transform: uppercase;
        letter-spacing: 3px;
        margin-bottom: 5px;
      }
      .subtitle {
        color: #ff007f;
        font-size: 1.2rem;
        text-shadow: 0 0 5px #ff007f;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 25px;
        max-width: 1200px;
        margin: 0 auto;
      }
      .card {
        border: 2px solid #00f3ff;
        padding: 25px;
        border-radius: 12px;
        background: rgba(0, 243, 255, 0.05);
        box-shadow: 0 0 15px rgba(0, 243, 255, 0.2);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }
      .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0 25px #00f3ff;
        background: rgba(0, 243, 255, 0.1);
      }
      .card h2 {
        color: #ff007f;
        margin-top: 0;
        font-size: 1.8rem;
        text-shadow: 0 0 8px rgba(255, 0, 127, 0.5);
      }
      .card p {
        font-size: 0.9rem;
        color: #aaa;
        word-break: break-all;
      }
      .back-link {
        display: block;
        text-align: center;
        margin-top: 60px;
        color: #fff;
        text-decoration: none;
        font-weight: bold;
        padding: 10px 20px;
        border: 1px solid #fff;
        border-radius: 5px;
        width: 200px;
        margin-left: auto;
        margin-right: auto;
        transition: 0.3s;
      }
      .back-link:hover {
        background: #fff;
        color: #0d0e15;
      }
  body
    .header
      h1 🎛️ Ambientes Ativos
      p.subtitle Monitoramento em tempo real das salas da festa
    
    .grid
      if salas && salas.length > 0
        each sala in salas
          .card
            h2 🎧 #{sala.nome}
            p 🆔 ID: #{sala._id || sala.id}
      else
        p(style="grid-column: 1/-1; text-align: center; color: #ff007f; font-size: 1.5rem;") 🚫 Nenhuma sala cadastrada no momento.
    
    a.back-link(href="/") ← Voltar ao Início