doctype html
html(lang="pt-BR")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Salas Ativas - Rave Party
    style.
      body {
        background-color: #0d0e15;
        color: #fff;
        font-family: 'Segoe UI', sans-serif;
        padding: 40px;
      }
      h1 {
        color: #00f3ff;
        text-shadow: 0 0 10px #00f3ff;
        text-align: center;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 20px;
        margin-top: 30px;
      }
      .card {
        border: 2px solid #ff007f;
        padding: 20px;
        border-radius: 10px;
        background: rgba(255, 0, 127, 0.02);
        box-shadow: 0 0 10px rgba(255, 0, 127, 0.2);
      }
      .card h2 {
        color: #ff007f;
        margin-top: 0;
      }
      .back-link {
        display: block;
        text-align: center;
        margin-top: 40px;
        color: #00f3ff;
        text-decoration: none;
      }
  body
    h1 🏛️ Linha do Tempo das Salas em Tempo Real
    .grid
      if salas && salas.length > 0
        each sala in salas
          .card
            h2 #{sala.nome}
            p 🆔 ID: #{sala._id || sala.id}
      else
        p(style="grid-column: 1/-1; text-align: center; color: #aaa;") Nenhuma sala cadastrada no momento.
    a.back-link(href="/") ← Voltar para a Página Inicial